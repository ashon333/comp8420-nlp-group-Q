        "    asp_results.append(row_data)\n",
        "\n",
        "asp_df = pd.DataFrame(asp_results)\n",
        "fig, axes = plt.subplots(1, 2, figsize=(15, 5))\n",
        "sns.heatmap(asp_df[ASPECTS].astype(float).T, cmap='RdYlGn', center=0, vmin=-1, vmax=1,\n",
